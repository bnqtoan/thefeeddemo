---
/**
 * /feed — Main newsfeed page.
 * Stories row at top (short videos), then mixed content feed with infinite scroll.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeedCard from "../../components/feed/FeedCard.astro";
import StoriesRow from "../../components/feed/StoriesRow.astro";
import StreamBox from "../../components/stream/StreamBox.astro";
import PodcastBox from "../../components/feed/PodcastBox.astro";
import { getPosts, getStream } from "../../lib/data";
import type { ShortVideoPost, AudioPlaylistPost } from "../../lib/types";

const shortVideos = (await getPosts("short-video")) as ShortVideoPost[];
const allPosts = await getPosts();
const feedPosts = allPosts
    .filter((p) => p.format !== "short-video")
    .slice(0, 10);
const streamItems = await getStream();
const formats = [
    { value: "all", label: "Tất cả" },
    { value: "article", label: "Bài viết" },
    { value: "video-embed", label: "Talks" },
    { value: "audio", label: "Audio" },
    { value: "audio-playlist", label: "Playlist" },
    { value: "quote", label: "Trích dẫn" },
    { value: "gallery", label: "Ảnh" },
];
const sorts = [
    { value: "newest", label: "Mới nhất" },
    { value: "oldest", label: "Cũ nhất" },
];
---

<BaseLayout title="Feed">
    <header class="pt-10 pb-6 md:pt-12 md:pb-8">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-2">
            Feed
        </h1>
        <p class="text-lg text-soft max-w-lg leading-relaxed">
            Workflow thật, process thật — kể cả failures.
        </p>
    </header>

    <!-- Stories row (short videos) -->
    <StoriesRow videos={shortVideos} />

    <!-- Stream box -->
    <StreamBox items={streamItems} />


    <!-- Filter & Sort row -->
    <div class="flex items-center justify-between gap-4 mb-8 flex-wrap">
        <!-- Format filter pills -->
        <div class="flex gap-2 flex-wrap" id="formatFilters">
            {
                formats.map((f) => (
                    <button
                        type="button"
                        class:list={[
                            "format-pill px-3.5 py-1.5 rounded-full text-sm font-medium border transition-all cursor-pointer",
                            f.value === "all"
                                ? "bg-ink text-white border-ink"
                                : "border-border text-soft hover:border-soft hover:text-ink",
                        ]}
                        data-format={f.value}
                    >
                        {f.label}
                    </button>
                ))
            }
        </div>
        <!-- Sort dropdown -->
        <div class="relative" id="sortDropdown">
            <button
                type="button"
                id="sortBtn"
                class="flex items-center gap-1.5 px-3 py-1.5 text-sm text-soft hover:text-ink transition-colors"
            >
                <svg
                    class="w-4 h-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <line x1="4" y1="6" x2="16" y2="6"></line>
                    <line x1="4" y1="12" x2="12" y2="12"></line>
                    <line x1="4" y1="18" x2="8" y2="18"></line>
                    <polyline points="15 15 18 18 21 15"></polyline>
                    <line x1="18" y1="9" x2="18" y2="18"></line>
                </svg>
                <span id="sortLabel">Mới nhất</span>
            </button>
            <div
                id="sortMenu"
                class="absolute right-0 top-full mt-1 bg-white border border-border rounded-lg shadow-lg py-1 min-w-[120px] hidden z-50"
            >
                {
                    sorts.map((s) => (
                        <button
                            type="button"
                            class:list={[
                                "sort-option w-full text-left px-3 py-2 text-sm hover:bg-ink/5 transition-colors",
                                s.value === "newest"
                                    ? "text-accent font-medium"
                                    : "text-soft",
                            ]}
                            data-sort={s.value}
                        >
                            {s.label}
                        </button>
                    ))
                }
            </div>
        </div>
    </div>

    <!-- Feed content -->
    <div id="feedContainer" class="flex flex-col gap-5">
        {
            feedPosts.map((post, i) => (
                <div class="animate-in" style={`--delay: ${i}`}>
                    <FeedCard post={post} />
                </div>
            ))
        }
    </div>

    <!-- Infinite scroll sentinel -->
    <div id="feedSentinel" class="py-12 flex justify-center">
        <div id="feedLoader" class="text-sm text-faint">Đang tải thêm...</div>
    </div>
</BaseLayout>

<script>
    import WaveSurfer from "wavesurfer.js";

    document.addEventListener("astro:page-load", () => {
        // Restore state from sessionStorage
        const savedState = sessionStorage.getItem("feedState");
        const state = savedState ? JSON.parse(savedState) : {};

        let currentPage = 1;
        let currentFormat = state.format || "all";
        let currentSort = state.sort || "newest";
        let isLoading = false;
        let hasMore = true;

        // Restore scroll position on back navigation
        if (state.scrollY && performance.getEntriesByType("navigation")[0]?.type === "back_forward") {
            setTimeout(() => window.scrollTo(0, state.scrollY), 0);
        }

        // Save state before leaving
        window.addEventListener("beforeunload", saveState);
        document.addEventListener("astro:before-preparation", saveState);

        function saveState() {
            sessionStorage.setItem("feedState", JSON.stringify({
                format: currentFormat,
                sort: currentSort,
                scrollY: window.scrollY
            }));
        }

        // WaveSurfer instances for dynamically loaded cards
        const dynWavesurfers = new Map<string, any>();
        let isSyncing = false;

        function formatTime(s: number): string {
            const m = Math.floor(s / 60);
            const sec = Math.floor(s % 60);
            return `${m}:${sec.toString().padStart(2, "0")}`;
        }

        // Sync waveform progress for dynamically loaded cards
        window.addEventListener("global-player-timeupdate", ((
            e: CustomEvent,
        ) => {
            const { currentTime, duration, src } = e.detail;
            dynWavesurfers.forEach((ws, key) => {
                // Find matching track element
                const trackEl = document.querySelector(
                    `[data-dyn-wave-key="${key}"]`,
                ) as HTMLElement;
                if (!trackEl) return;
                const trackUrl =
                    trackEl.dataset.trackUrl || trackEl.dataset.audioUrl || "";
                if (src && src.includes(trackUrl) && duration > 0) {
                    isSyncing = true;
                    ws.seekTo(currentTime / duration);
                    isSyncing = false;
                    const currentEl = trackEl.querySelector(
                        ".track-current, .wave-current",
                    ) as HTMLElement;
                    if (currentEl)
                        currentEl.textContent = formatTime(currentTime);
                }
            });
        }) as EventListener);

        // Sync play/pause state for dynamically loaded playlist tracks
        window.addEventListener("global-player-state", ((e: CustomEvent) => {
            const { playing, src } = e.detail;
            // Playlist tracks
            container
                ?.querySelectorAll(".playlist-track")
                .forEach((trackEl) => {
                    const el = trackEl as HTMLElement;
                    const trackUrl = el.dataset.trackUrl || "";
                    const isThisTrack = src && src.includes(trackUrl);
                    if (isThisTrack && playing) {
                        el.classList.add("active", "playing");
                    } else if (isThisTrack && !playing) {
                        el.classList.add("active");
                        el.classList.remove("playing");
                    } else {
                        el.classList.remove("active", "playing");
                        el.querySelector(".track-waveform")?.classList.add(
                            "hidden",
                        );
                    }
                });
            // Audio cards
            container?.querySelectorAll("[data-audio-card]").forEach((card) => {
                const el = card as HTMLElement;
                const cardUrl = el.dataset.audioUrl || "";
                const isThis = src && src.includes(cardUrl);
                const playIcon = el.querySelector(".play-icon") as HTMLElement;
                const pauseIcon = el.querySelector(
                    ".pause-icon",
                ) as HTMLElement;
                if (isThis && playing) {
                    playIcon?.classList.add("hidden");
                    pauseIcon?.classList.remove("hidden");
                    el.querySelector(".waveform-wrap")?.classList.remove(
                        "hidden",
                    );
                } else if (isThis && !playing) {
                    playIcon?.classList.remove("hidden");
                    pauseIcon?.classList.add("hidden");
                } else {
                    playIcon?.classList.remove("hidden");
                    pauseIcon?.classList.add("hidden");
                }
            });
        }) as EventListener);

        function createDynWaveSurfer(
            containerId: string,
            key: string,
            audioUrl: string,
        ): any {
            if (dynWavesurfers.has(key)) return dynWavesurfers.get(key);
            const el = document.getElementById(containerId);
            if (!el) return null;
            const ws = WaveSurfer.create({
                container: `#${containerId}`,
                waveColor: "#c4b5fd",
                progressColor: "#1d4ed8",
                cursorColor: "#1d4ed8",
                cursorWidth: 2,
                barWidth: 2,
                barGap: 1,
                barRadius: 2,
                height: 36,
                url: audioUrl,
                interact: true,
                backend: "WebAudio",
            });
            ws.setVolume(0);
            ws.on("ready", () => ws.setVolume(0));
            ws.on("seeking", (currentTime: number) => {
                if (isSyncing) return;
                const globalAudioEl = (window as any)
                    .globalAudioEl as HTMLAudioElement;
                if (globalAudioEl && globalAudioEl.src.includes(audioUrl)) {
                    globalAudioEl.currentTime = currentTime;
                }
            });
            dynWavesurfers.set(key, ws);
            return ws;
        }

        const container = document.getElementById("feedContainer");
        const sentinel = document.getElementById("feedSentinel");
        const loader = document.getElementById("feedLoader");
        if (!container || !sentinel) return;

        // Apply saved filter state on load
        if (currentFormat !== "all") {
            document.querySelectorAll(".format-pill").forEach((b) => {
                const fmt = (b as HTMLElement).dataset.format;
                if (fmt === currentFormat) {
                    b.classList.add("bg-ink", "text-white", "border-ink");
                    b.classList.remove("border-border", "text-soft");
                } else {
                    b.classList.remove("bg-ink", "text-white", "border-ink");
                    b.classList.add("border-border", "text-soft");
                }
            });
        }

        // Apply saved sort state on load
        const sortLabel = document.getElementById("sortLabel");
        const sortLabels: Record<string, string> = { newest: "Mới nhất", oldest: "Cũ nhất" };
        if (sortLabel && currentSort !== "newest") {
            sortLabel.textContent = sortLabels[currentSort] || "Mới nhất";
            document.querySelectorAll(".sort-option").forEach((opt) => {
                const val = (opt as HTMLElement).dataset.sort;
                if (val === currentSort) {
                    opt.classList.add("text-accent", "font-medium");
                    opt.classList.remove("text-soft");
                } else {
                    opt.classList.remove("text-accent", "font-medium");
                    opt.classList.add("text-soft");
                }
            });
        }

        // Format filter pills
        document.querySelectorAll(".format-pill").forEach((btn) => {
            btn.addEventListener("click", async () => {
                const format = (btn as HTMLElement).dataset.format!;
                if (format === currentFormat) return;

                document.querySelectorAll(".format-pill").forEach((b) => {
                    b.classList.remove("bg-ink", "text-white", "border-ink");
                    b.classList.add("border-border", "text-soft");
                });
                btn.classList.add("bg-ink", "text-white", "border-ink");
                btn.classList.remove("border-border", "text-soft");

                currentFormat = format;
                currentPage = 0;
                hasMore = true;
                container.innerHTML = "";
                await loadPosts();
            });
        });

        // Sort dropdown
        const sortBtn = document.getElementById("sortBtn");
        const sortMenu = document.getElementById("sortMenu");

        sortBtn?.addEventListener("click", (e) => {
            e.stopPropagation();
            sortMenu?.classList.toggle("hidden");
        });

        document.addEventListener("click", () => {
            sortMenu?.classList.add("hidden");
        });

        document.querySelectorAll(".sort-option").forEach((opt) => {
            opt.addEventListener("click", async () => {
                const sort = (opt as HTMLElement).dataset.sort!;
                if (sort === currentSort) {
                    sortMenu?.classList.add("hidden");
                    return;
                }

                document.querySelectorAll(".sort-option").forEach((o) => {
                    o.classList.remove("text-accent", "font-medium");
                    o.classList.add("text-soft");
                });
                opt.classList.add("text-accent", "font-medium");
                opt.classList.remove("text-soft");

                if (sortLabel) sortLabel.textContent = sortLabels[sort] || sort;
                sortMenu?.classList.add("hidden");

                currentSort = sort;
                currentPage = 0;
                hasMore = true;
                container.innerHTML = "";
                await loadPosts();
            });
        });

        async function loadPosts() {
            if (isLoading || !hasMore) return;
            isLoading = true;
            if (loader) {
                loader.textContent = "Đang tải...";
                loader.classList.remove("hidden");
            }

            try {
                currentPage++;
                const res = await fetch(
                    `/api/feed?page=${currentPage}&format=${currentFormat}&sort=${currentSort}`,
                );
                const data = await res.json();
                appendPosts(data.posts);
                hasMore = data.hasMore;
            } catch (e) {
                console.error("Feed load error:", e);
            } finally {
                isLoading = false;
                if (!hasMore && loader) {
                    loader.textContent = "Đã xem hết ✓";
                }
            }
        }

        function appendPosts(posts: any[]) {
            posts.forEach((post, i) => {
                const wrapper = document.createElement("div");
                wrapper.className = "animate-in";
                wrapper.style.setProperty("--delay", String(i));
                wrapper.innerHTML = wrapWithShare(post, renderPostCard(post));
                container!.appendChild(wrapper);
            });
        }

        // Share button HTML to wrap around cards
        function shareButtonHtml(post: any): string {
            const pd = JSON.stringify({
                slug: post.slug,
                title: post.title,
                subtitle: post.subtitle || "",
                format: post.format,
                quoteText: post.quoteText || "",
                attribution: post.attribution || "",
                tags: post.tags || [],
                heroImage:
                    post.heroImage || post.coverImage || post.thumbnail || "",
                duration: post.duration || 0,
                tracks: (post.tracks || []).map((t: any) => ({
                    title: t.title,
                    duration: t.duration,
                })),
                images: (post.images || [])
                    .slice(0, 4)
                    .map((img: any) => img.url),
            }).replace(/"/g, "&quot;");
            return `<div class="card-actions"><button type="button" class="share-img-btn" data-post="${pd}" aria-label="Share as image" title="Share as image"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></button><button type="button" class="share-btn" data-slug="${post.slug}" aria-label="Share" title="Copy link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg><span class="share-toast">Link copied!</span></button></div>`;
        }

        function wrapWithShare(post: any, cardHtml: string): string {
            return `<div class="feed-card-wrapper" id="post-${post.slug}">${cardHtml}${shareButtonHtml(post)}</div>`;
        }

        function renderPostCard(post: any): string {
            switch (post.format) {
                case "article":
                    return `<a href="/${post.slug}" class="group block py-5 border-t border-[var(--color-border)] transition-colors hover:bg-[var(--color-ink)]/[0.015]">
            <div class="flex justify-between items-baseline mb-1.5">
              <h3 class="font-[var(--font-heading)] text-xl font-semibold tracking-tight transition-colors group-hover:text-[var(--color-accent)]">${post.title}</h3>
              <span class="text-xs font-semibold text-[var(--color-soft)] uppercase tracking-wide ml-4 shrink-0">${post.stage || ""}</span>
            </div>
            ${post.subtitle ? `<p class="text-base text-[var(--color-soft)]">${post.subtitle}</p>` : ""}
          </a>`;

                case "quote":
                    return `<div class="rounded-xl bg-gradient-to-br from-[var(--color-accent-soft)] to-white border border-[var(--color-accent-mid)] p-6">
            <blockquote class="font-[var(--font-heading)] text-xl font-medium text-[var(--color-accent)] leading-relaxed italic">"${post.quoteText}"</blockquote>
            ${post.attribution ? `<p class="text-sm font-medium text-[var(--color-soft)] mt-3">— ${post.attribution}</p>` : ""}
          </div>`;

                case "video-embed":
                    const thumb =
                        post.provider === "youtube"
                            ? `https://img.youtube.com/vi/${post.videoId}/maxresdefault.jpg`
                            : "";
                    return `<a href="/${post.slug}" class="group block">
            <div class="relative aspect-video rounded-xl overflow-hidden bg-[var(--color-ink)]/5">
              <img src="${thumb}" alt="${post.title}" class="w-full h-full object-cover" loading="lazy" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center shadow-lg">
                  <svg class="w-6 h-6 text-[var(--color-ink)] ml-1" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </div>
            <h3 class="mt-3 font-semibold text-lg">${post.title}</h3>
            ${post.subtitle ? `<p class="mt-1 text-[var(--color-soft)] text-[15px]">${post.subtitle}</p>` : ""}
          </a>`;

                case "audio":
                    const audioId = `dyn-wave-${post.slug}`;
                    return `<div class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] overflow-hidden" data-audio-card="${post.slug}">
            <div class="flex gap-4 p-4">
              ${post.coverImage ? `<div class="w-14 h-14 rounded-lg overflow-hidden shrink-0 bg-[var(--color-accent-soft)]"><img src="${post.coverImage}" alt="${post.title}" class="w-full h-full object-cover" loading="lazy" /></div>` : '<div class="w-14 h-14 rounded-lg bg-gradient-to-br from-[var(--color-accent-soft)] to-[var(--color-accent-mid)] flex items-center justify-center shrink-0"><svg class="w-6 h-6 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>'}
              <div class="flex-1 min-w-0">
                <h3 class="font-medium text-[15px] leading-snug truncate">${post.title}</h3>
                ${post.subtitle ? `<p class="text-sm text-[var(--color-soft)] mt-0.5 line-clamp-1">${post.subtitle}</p>` : ""}
                <span class="text-xs text-[var(--color-faint)] mt-1 block">${formatDuration(post.duration)}</span>
              </div>
              <button type="button" class="audio-play-btn self-center w-10 h-10 rounded-full bg-[var(--color-accent)] text-white flex items-center justify-center shrink-0 hover:opacity-80 transition-colors" data-audio-url="${post.audioUrl}" data-audio-title="${post.title}" data-audio-subtitle="${post.subtitle || ""}" data-audio-cover="${post.coverImage || ""}" data-audio-slug="${post.slug}" aria-label="Play ${post.title}">
                <svg class="w-5 h-5 ml-0.5 play-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                <svg class="w-5 h-5 pause-icon hidden" viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h4v16H6zM14 4h4v16h-4z"/></svg>
              </button>
            </div>
            <div class="waveform-wrap px-4 pb-3 hidden" data-slug="${post.slug}">
              <div class="waveform-container" id="${audioId}" style="border-radius:6px;overflow:hidden;cursor:pointer"></div>
              <div class="flex justify-between text-[11px] text-[var(--color-faint)] mt-1" style="font-variant-numeric:tabular-nums">
                <span class="wave-current">0:00</span>
                <span class="wave-duration">${formatDuration(post.duration)}</span>
              </div>
            </div>
          </div>`;

                case "audio-playlist":
                    const plTracks = post.tracks || [];
                    const totalDur = plTracks.reduce(
                        (s: number, t: any) => s + (t.duration || 0),
                        0,
                    );
                    return `<div class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] overflow-hidden" data-playlist-card="${post.slug}">
            <div class="flex gap-4 p-4">
              ${post.coverImage ? `<div class="w-16 h-16 rounded-lg overflow-hidden shrink-0"><img src="${post.coverImage}" class="w-full h-full object-cover" loading="lazy" /></div>` : '<div class="w-16 h-16 rounded-lg bg-gradient-to-br from-[var(--color-accent-soft)] to-[var(--color-accent-mid)] flex items-center justify-center shrink-0"><svg class="w-7 h-7 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>'}
              <div class="flex-1 min-w-0">
                <h3 class="font-[var(--font-heading)] font-semibold text-base">${post.title}</h3>
                ${post.subtitle ? `<p class="text-sm text-[var(--color-soft)] mt-0.5 line-clamp-1">${post.subtitle}</p>` : ""}
                <div class="flex gap-3 mt-2 text-xs text-[var(--color-faint)]">
                  <span>${plTracks.length} tracks</span><span>·</span><span>${formatDuration(totalDur)}</span>
                </div>
              </div>
            </div>
            <div class="border-t border-[var(--color-border)]">
              ${plTracks
                  .map(
                      (
                          t: any,
                          i: number,
                      ) => `<div class="playlist-track" data-track-index="${i}" data-track-url="${t.audioUrl}" data-track-title="${t.title}" data-playlist-slug="${post.slug}">
                <div class="flex items-center gap-3 px-4 py-2.5 text-sm hover:bg-[var(--color-ink)]/[0.03] cursor-pointer transition-colors track-row">
                  <span class="track-num text-[var(--color-faint)] text-xs w-5 text-center shrink-0"><span class="num-text">${i + 1}</span><svg class="play-indicator hidden w-3.5 h-3.5 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg><svg class="pause-indicator hidden w-3.5 h-3.5 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h4v16H6zM14 4h4v16h-4z"/></svg></span>
                  <span class="flex-1 truncate track-title">${t.title}</span>
                  <span class="text-xs text-[var(--color-faint)]">${formatDuration(t.duration)}</span>
                </div>
                <div class="track-waveform px-4 pb-2 hidden">
                  <div class="waveform-el" id="playlist-wave-${post.slug}-${i}" style="border-radius:4px;overflow:hidden;cursor:pointer"></div>
                  <div class="flex justify-between text-[10px] text-[var(--color-faint)] mt-1" style="font-variant-numeric:tabular-nums">
                    <span class="track-current">0:00</span>
                    <span class="track-duration">${formatDuration(t.duration)}</span>
                  </div>
                </div>
              </div>`,
                  )
                  .join("")}
            </div>
          </div>`;

                case "gallery":
                    const imgs = (post.images || []).slice(0, 4);
                    return `<a href="/${post.slug}" class="group block">
            <div class="grid grid-cols-2 gap-1 rounded-xl overflow-hidden aspect-[2/1]">
              ${imgs.map((img: any) => `<div class="overflow-hidden bg-[var(--color-ink)]/5"><img src="${img.url}" alt="${img.caption || ""}" class="w-full h-full object-cover" loading="lazy" /></div>`).join("")}
            </div>
            <h3 class="mt-3 font-semibold text-lg">${post.title}</h3>
            <span class="text-xs text-[var(--color-faint)]">${post.images?.length || 0} photos</span>
          </a>`;

                default:
                    return `<div class="py-4 border-t border-[var(--color-border)]">
            <h3 class="font-semibold">${post.title}</h3>
          </div>`;
            }
        }

        function formatDuration(seconds: number): string {
            const m = Math.floor(seconds / 60);
            const s = seconds % 60;
            return `${m}:${s.toString().padStart(2, "0")}`;
        }

        // Infinite scroll
        const observer = new IntersectionObserver(
            (entries) => {
                if (entries[0].isIntersecting && hasMore && !isLoading) {
                    loadPosts();
                }
            },
            { rootMargin: "200px" },
        );
        observer.observe(sentinel);

        // Delegated click handler for dynamically created share buttons
        container.addEventListener("click", async (e) => {
            // Image share button
            const imgBtn = (e.target as HTMLElement).closest(
                ".share-img-btn",
            ) as HTMLElement;
            if (imgBtn) {
                e.preventDefault();
                e.stopPropagation();
                try {
                    const data = JSON.parse(imgBtn.dataset.post || "{}");
                    if ((window as any).openShareImageModal) {
                        (window as any).openShareImageModal(data);
                    }
                } catch (err) {
                    console.error("Share image error:", err);
                }
                return;
            }

            // Link copy button
            const btn = (e.target as HTMLElement).closest(
                ".share-btn",
            ) as HTMLElement;
            if (btn) {
                e.preventDefault();
                e.stopPropagation();
                const slug = btn.dataset.slug!;
                const url = `${window.location.origin}/feed#post-${slug}`;
                try {
                    await navigator.clipboard.writeText(url);
                } catch {
                    const inp = document.createElement("input");
                    inp.value = url;
                    document.body.appendChild(inp);
                    inp.select();
                    document.execCommand("copy");
                    inp.remove();
                }
                const toast = btn.querySelector(".share-toast");
                toast?.classList.add("visible");
                setTimeout(() => toast?.classList.remove("visible"), 1500);
                return;
            }

            // ====== Playlist track click (delegated) ======
            // Only handle dynamically rendered tracks. Server-rendered tracks
            // are handled by FeedCardAudioPlaylist.astro's own script (which
            // sets data-track-key on the element during init).
            const trackRow = (e.target as HTMLElement).closest(
                ".track-row",
            ) as HTMLElement;
            const trackEl = trackRow?.closest(".playlist-track") as HTMLElement;
            if (trackRow && trackEl && !trackEl.dataset.trackKey) {
                const url = trackEl.dataset.trackUrl!;
                const title = trackEl.dataset.trackTitle!;
                const index = parseInt(trackEl.dataset.trackIndex!);
                const playlistSlug = trackEl.dataset.playlistSlug!;

                const globalAudioEl = (window as any)
                    .globalAudioEl as HTMLAudioElement;
                const globalPlay = (window as any).globalPlayerPlay;

                // If this track is already playing, toggle
                if (globalAudioEl && globalAudioEl.src.includes(url)) {
                    if (globalAudioEl.paused)
                        globalAudioEl.play().catch(() => {});
                    else globalAudioEl.pause();
                    return;
                }

                // Reset all tracks in the feed
                container.querySelectorAll(".playlist-track").forEach((t) => {
                    (t as HTMLElement).classList.remove("active", "playing");
                    t.querySelector(".track-waveform")?.classList.add("hidden");
                });

                // Activate this track
                trackEl.classList.add("active");
                const waveWrap = trackEl.querySelector(
                    ".track-waveform",
                ) as HTMLElement;
                if (waveWrap) waveWrap.classList.remove("hidden");

                // Create WaveSurfer for this track
                const key = `${playlistSlug}-${index}`;
                trackEl.dataset.dynWaveKey = key;
                const containerId = `playlist-wave-${playlistSlug}-${index}`;
                createDynWaveSurfer(containerId, key, url);

                // Build playlist from all tracks in this card
                const playlistCard = trackEl.closest("[data-playlist-card]");
                const allTracks = playlistCard
                    ? (Array.from(
                          playlistCard.querySelectorAll(".playlist-track"),
                      ) as HTMLElement[])
                    : [];
                const playlist = allTracks.map((t) => ({
                    url: t.dataset.trackUrl!,
                    title: t.dataset.trackTitle!,
                    subtitle: "",
                    coverImage: "",
                    slug: `${t.dataset.playlistSlug}-${t.dataset.trackIndex}`,
                }));

                // Play via global player
                if (globalPlay) {
                    const playlistTitle =
                        playlistCard?.querySelector("h3")?.textContent ||
                        "Playlist";
                    globalPlay(
                        url,
                        `${playlistTitle} — ${title}`,
                        "",
                        "",
                        `${playlistSlug}-${index}`,
                        playlist,
                    );
                }
                return;
            }

            // ====== Audio play button click (delegated) ======
            // Only handle dynamically rendered buttons (they carry data-audio-url).
            // Server-rendered FeedCardAudio cards are handled by their own component script.
            const audioBtn = (e.target as HTMLElement).closest(
                ".audio-play-btn",
            ) as HTMLElement;
            if (audioBtn && audioBtn.dataset.audioUrl) {
                const audioUrl = audioBtn.dataset.audioUrl;
                const title = audioBtn.dataset.audioTitle || "";
                const subtitle = audioBtn.dataset.audioSubtitle || "";
                const cover = audioBtn.dataset.audioCover || "";
                const slug = audioBtn.dataset.audioSlug || "";

                const globalAudioEl = (window as any)
                    .globalAudioEl as HTMLAudioElement;
                const globalPlay = (window as any).globalPlayerPlay;

                // If already playing this audio, toggle
                if (globalAudioEl && globalAudioEl.src.includes(audioUrl)) {
                    if (globalAudioEl.paused)
                        globalAudioEl.play().catch(() => {});
                    else globalAudioEl.pause();
                    return;
                }

                // Show waveform area and create WaveSurfer
                const audioCard = audioBtn.closest(
                    "[data-audio-card]",
                ) as HTMLElement;
                if (audioCard) {
                    const waveWrap = audioCard.querySelector(
                        ".waveform-wrap",
                    ) as HTMLElement;
                    if (waveWrap) waveWrap.classList.remove("hidden");
                    const waveKey = `audio-${slug}`;
                    audioCard.dataset.dynWaveKey = waveKey;
                    const waveContainerId = `dyn-wave-${slug}`;
                    createDynWaveSurfer(waveContainerId, waveKey, audioUrl);
                }

                // Play via global player
                if (globalPlay) {
                    globalPlay(audioUrl, title, subtitle, cover, slug);
                }
                return;
            }
        });
    });
</script>
