---
/**
 * /jokes — Dad jokes masonry grid.
 * Pinterest-style cards, auto-sizing based on content length.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const jokes = (await getCollection("jokes"))
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Jokes">
    <header class="pt-10 pb-8 md:pt-12 md:pb-10">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-2">
            Cợt nhả nghiêm túc
        </h1>
        <p class="text-lg text-soft max-w-lg leading-relaxed">
            Dad jokes, deep thoughts, và những thứ linh tinh.
        </p>
    </header>

    <!-- Masonry grid -->
    <div class="jokes-grid" id="jokesGrid">
        {jokes.map((joke, i) => (
            <div
                class:list={["joke-card group", joke.data.image && "has-image"]}
                data-joke-id={joke.id}
                data-joke-text={joke.data.text || ""}
                data-joke-image={joke.data.image || ""}
                style={`--delay: ${i % 10}`}
            >
                <span class="joke-number">#{jokes.length - i}</span>
                {joke.data.image && (
                    <img
                        src={joke.data.image}
                        alt={joke.data.text || "Meme"}
                        class="joke-image"
                        loading="lazy"
                    />
                )}
                {joke.data.text && <p class="joke-text">{joke.data.text}</p>}
                <div class="joke-footer">
                    <span class="joke-date">
                        {new Date(joke.data.date).toLocaleDateString("vi-VN", {
                            day: "numeric",
                            month: "short",
                        })}
                    </span>
                    <button
                        type="button"
                        class="joke-share-btn"
                        data-text={joke.data.text || ""}
                        data-image={joke.data.image || ""}
                        aria-label="Share as image"
                        title="Share as image"
                    >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <polyline points="21 15 16 10 5 21"></polyline>
                        </svg>
                    </button>
                </div>
            </div>
        ))}
    </div>
</BaseLayout>

<style>
    .jokes-grid {
        columns: 1;
        column-gap: 16px;
    }

    @media (min-width: 640px) {
        .jokes-grid {
            columns: 2;
        }
    }

    @media (min-width: 1024px) {
        .jokes-grid {
            columns: 3;
        }
    }

    .joke-card {
        break-inside: avoid;
        margin-bottom: 16px;
        padding: 20px;
        background: var(--color-card, #fff);
        border: 1px solid var(--color-border, #e8e8e5);
        border-radius: 16px;
        transition: all 0.2s ease;
        animation: fadeInUp 0.4s ease both;
        animation-delay: calc(var(--delay) * 0.05s);
    }

    .joke-card:hover {
        border-color: var(--color-soft, #aaa);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        transform: translateY(-2px);
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .joke-number {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.05em;
        color: var(--color-accent, #1d4ed8);
        opacity: 0.5;
        margin-bottom: 8px;
    }

    .joke-card.has-image {
        padding: 0;
        overflow: hidden;
    }

    .joke-card.has-image .joke-number {
        position: absolute;
        top: 12px;
        left: 12px;
        background: rgba(255, 255, 255, 0.9);
        padding: 4px 8px;
        border-radius: 6px;
        margin: 0;
        z-index: 1;
    }

    .joke-card.has-image {
        position: relative;
    }

    .joke-image {
        width: 100%;
        display: block;
        border-radius: 0;
    }

    .joke-card.has-image .joke-text {
        padding: 16px 20px 0;
    }

    .joke-card.has-image .joke-footer {
        margin: 16px 20px 0;
        padding-bottom: 16px;
    }

    .joke-text {
        font-size: 16px;
        line-height: 1.6;
        color: var(--color-ink, #1a1a1a);
        white-space: pre-line;
        margin: 0;
    }

    .joke-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 16px;
        padding-top: 12px;
        border-top: 1px solid var(--color-border, #e8e8e5);
    }

    .joke-date {
        font-size: 12px;
        color: var(--color-faint, #aaa);
    }

    .joke-share-btn {
        width: 32px;
        height: 32px;
        border: none;
        background: transparent;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-soft, #888);
        opacity: 0;
        transition: all 0.2s;
    }

    .joke-card:hover .joke-share-btn {
        opacity: 1;
    }

    .joke-share-btn:hover {
        background: var(--color-ink, #1a1a1a);
        color: #fff;
    }

    .joke-share-btn svg {
        width: 16px;
        height: 16px;
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        // Share button click handler
        document.querySelectorAll(".joke-share-btn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.preventDefault();
                e.stopPropagation();

                const el = btn as HTMLElement;
                const text = el.dataset.text || "";
                const image = el.dataset.image || "";

                if ((window as any).openShareImageModal) {
                    // Pure image meme (no text) - use meme format
                    if (image && !text) {
                        (window as any).openShareImageModal({
                            slug: "meme",
                            title: "Meme",
                            format: "meme",
                            rawImageUrl: image,
                        });
                    } else {
                        // Text jokes - use joke format
                        (window as any).openShareImageModal({
                            slug: "joke",
                            title: text || "Meme",
                            subtitle: "",
                            format: "joke",
                            quoteText: text,
                            attribution: "Cợt nhả nghiêm túc",
                            tags: ["dadjokes"],
                        });
                    }
                }
            });
        });
    });
</script>
