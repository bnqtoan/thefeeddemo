---
/**
 * /stream/[slug] — Individual stream item detail page.
 * Accessible via direct URL or when users refresh while the modal URL is active.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
    ExternalLink,
    MessageCircle,
    ArrowLeft,
    Link,
    Share2,
} from "@lucide/astro";
import { getCollection, render } from "astro:content";
import { getStream } from "../../lib/data";

const rawSlug = Astro.params.slug || "";

// ─── Stream redirects (old slug → new slug) ───
const STREAM_REDIRECTS: Record<string, string> = {
    "repomix-vs-vfs-hai-cach-cho-ai-doc-code-tiet-kiem-token-3jmlax": "repomix-va-vfs-bo-doi-toi-uu-token-cho-ai-coding-3jmlax",
};

if (STREAM_REDIRECTS[rawSlug]) {
    return Astro.redirect(`/stream/${STREAM_REDIRECTS[rawSlug]}`, 301);
}

const slug = rawSlug;

// Find the entry in the stream collection
const entries = await getCollection(
    "stream",
    (entry) => entry.data.status === "published",
);
const entry = entries.find((e) => e.id.replace(/\.mdx?$/, "") === slug);

if (!entry) {
    return new Response(null, { status: 404, statusText: "Not Found" });
}

const d = entry.data;
const isLink = d.type === "link";

// Render MDX content
const { Content } = await render(entry);

// Extract excerpt from raw body for share image
function getExcerpt(raw: string | undefined, maxLength = 150): string {
    if (!raw) return "";
    const text = raw.replace(/^---[\s\S]*?---\s*/m, "").replace(/^#+\s+.*/gm, "").replace(/!\[.*?\]\(.*?\)/g, "").replace(/\[([^\]]*)\]\(.*?\)/g, "$1").replace(/[*_`~]/g, "").replace(/\n+/g, " ").replace(/\s+/g, " ").trim();
    if (!text) return "";
    const first = text.split(/[.!?]\s/)[0];
    if (first.length <= maxLength) return first + (text.length > first.length ? "..." : "");
    return text.slice(0, maxLength).trim() + "...";
}
const shareExcerpt = getExcerpt(entry.body);

// Relative time
function relativeTime(dateStr: string): string {
    const now = new Date();
    const date = new Date(dateStr);
    const diffMs = now.getTime() - date.getTime();
    const diffMin = Math.floor(diffMs / 60000);
    if (diffMin < 1) return "vừa xong";
    if (diffMin < 60) return `${diffMin} phút trước`;
    const diffHr = Math.floor(diffMin / 60);
    if (diffHr < 24) return `${diffHr} giờ trước`;
    const diffDay = Math.floor(diffHr / 24);
    if (diffDay < 7) return `${diffDay} ngày trước`;
    return date.toLocaleDateString("vi-VN", {
        day: "numeric",
        month: "long",
        year: "numeric",
    });
}

const timeAgo = relativeTime(d.date);

// Get other stream items for "more" section
const allStream = await getStream();
const otherItems = allStream.filter((i) => i.slug !== slug).slice(0, 3);
---

<BaseLayout title={d.title}>
    <article class="max-w-2xl mx-auto pb-16">
        <!-- Back + share bar -->
        <div class="flex items-center justify-between pt-8 pb-6">
            <a
                href="/stream"
                class="text-sm text-soft hover:text-ink transition-colors flex items-center gap-1.5"
            >
                <ArrowLeft class="w-4 h-4" />
                Stream
            </a>
            <div class="flex items-center gap-2">
                <button
                    type="button"
                    class="stream-share-image-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-[var(--color-border)] text-[13px] font-medium text-[var(--color-soft)] hover:text-[var(--color-ink)] hover:border-[var(--color-soft)] transition-all cursor-pointer"
                    data-title={d.title}
                    data-slug={slug}
                    data-type={d.type}
                    data-tags={JSON.stringify(d.tags)}
                    data-excerpt={shareExcerpt}
                    aria-label="Share as image"
                    title="Share as image"
                >
                    <svg
                        class="w-3.5 h-3.5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"
                        ></rect>
                        <circle cx="8.5" cy="8.5" r="1.5"></circle>
                        <polyline points="21 15 16 10 5 21"></polyline>
                    </svg>
                    Ảnh
                </button>
                <button
                    type="button"
                    class="stream-copy-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-[var(--color-border)] text-[13px] font-medium text-[var(--color-soft)] hover:text-[var(--color-ink)] hover:border-[var(--color-soft)] transition-all cursor-pointer"
                    data-slug={`stream/${slug}`}
                    aria-label="Copy link"
                    title="Copy link"
                >
                    <Link class="w-3.5 h-3.5" />
                    <span class="stream-copy-label">Link</span>
                </button>
                <button
                    type="button"
                    class="stream-native-share inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-[var(--color-border)] text-[13px] font-medium text-[var(--color-soft)] hover:text-[var(--color-ink)] hover:border-[var(--color-soft)] transition-all cursor-pointer"
                    data-title={d.title}
                    aria-label="Share"
                    title="Share"
                    style="display:none"
                >
                    <Share2 class="w-3.5 h-3.5" />
                    Share
                </button>
            </div>
        </div>

        <!-- Header -->
        <header class="mb-8 animate-in" style="--delay: 0">
            <div class="flex items-center gap-2 mb-3">
                <span
                    class:list={[
                        "w-8 h-8 rounded-lg flex items-center justify-center",
                        isLink
                            ? "bg-blue-50 text-blue-600"
                            : "bg-violet-50 text-violet-600",
                    ]}
                >
                    {
                        isLink ? (
                            <ExternalLink class="w-4 h-4" />
                        ) : (
                            <MessageCircle class="w-4 h-4" />
                        )
                    }
                </span>
                <span
                    class="text-[13px] font-semibold text-accent uppercase tracking-widest"
                >
                    {isLink ? "Liên kết" : "Bài ngắn"}
                </span>
            </div>
            <h1
                class="text-2xl md:text-3xl font-semibold tracking-tight leading-tight mb-3"
            >
                {d.title}
            </h1>
            <div class="flex items-center gap-2 text-sm text-faint">
                <time>{timeAgo}</time>
                {
                    isLink && d.source && (
                        <>
                            <span>·</span>
                            <span class="font-medium">{d.source}</span>
                        </>
                    )
                }
            </div>
        </header>

        <!-- Tab buttons (only for links) -->
        {
            isLink && (
                <div
                    id="stream-detail-tabs"
                    class="sticky top-0 z-40 flex gap-1 mb-6 p-1.5 bg-[var(--color-bg)] backdrop-blur-sm rounded-lg w-fit animate-in"
                    style="--delay: 1"
                >
                    <button
                        type="button"
                        id="tab-recap"
                        class="px-4 py-2 text-sm font-medium rounded-md transition-colors bg-white text-[var(--color-ink)] shadow-sm"
                    >
                        Tóm tắt
                    </button>
                    <button
                        type="button"
                        id="tab-full"
                        class="px-4 py-2 text-sm font-medium rounded-md transition-colors text-[var(--color-soft)] hover:text-[var(--color-ink)]"
                        data-slug={slug}
                    >
                        Nội dung gốc
                    </button>
                </div>
            )
        }

        <!-- Recap content (default) -->
        <div id="recap-content" class="prose-content animate-in" style="--delay: 1">
            <Content />
        </div>

        <!-- Full content (lazy loaded) -->
        <div id="full-content" class="hidden animate-in" style="--delay: 1">
            <div id="full-loading" class="hidden py-12 text-center">
                <div
                    class="inline-block w-6 h-6 border-2 border-[var(--color-accent)] border-t-transparent rounded-full animate-spin"
                >
                </div>
                <p class="mt-3 text-sm text-[var(--color-soft)]">
                    Đang tải nội dung...
                </p>
            </div>
            <div id="full-body" class="prose-content"></div>
            <div
                id="full-meta"
                class="hidden mt-6 pt-6 border-t border-[var(--color-border)] text-sm text-[var(--color-faint)]"
            >
            </div>
        </div>

        <!-- External link button -->
        {
            isLink && d.url && (
                <div class="mt-6 animate-in" style="--delay: 2">
                    <a
                        href={d.url}
                        target="_blank"
                        rel="noopener noreferrer nofollow"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold bg-[var(--color-accent)] text-white hover:opacity-90 transition-opacity"
                    >
                        Truy cập
                        <ExternalLink class="w-4 h-4" />
                    </a>
                </div>
            )
        }

        <!-- Tags -->
        {
            d.tags.length > 0 && (
                <div
                    class="flex flex-wrap gap-2 mt-6 animate-in"
                    style="--delay: 3"
                >
                    {d.tags.map((tag) => (
                        <span class="text-xs px-2.5 py-1 rounded-full border border-border text-faint">
                            #{tag}
                        </span>
                    ))}
                </div>
            )
        }

        <!-- More stream items -->
        {
            otherItems.length > 0 && (
                <div
                    class="mt-16 pt-12 border-t border-border animate-in"
                    style="--delay: 4"
                >
                    <h3 class="text-xl font-semibold mb-6 font-heading">
                        Cập nhật khác
                    </h3>
                    <div class="flex flex-col gap-4">
                        {otherItems.map((item) => (
                            <a
                                href={`/stream/${item.slug}`}
                                class="group flex items-start gap-3 py-3 border-t border-[var(--color-border)] transition-colors hover:bg-[var(--color-ink)]/[0.015]"
                            >
                                <span
                                    class:list={[
                                        "mt-0.5 w-6 h-6 rounded-md flex items-center justify-center shrink-0",
                                        item.type === "link"
                                            ? "bg-blue-50 text-blue-600"
                                            : "bg-violet-50 text-violet-600",
                                    ]}
                                >
                                    {item.type === "link" ? (
                                        <ExternalLink class="w-3.5 h-3.5" />
                                    ) : (
                                        <MessageCircle class="w-3.5 h-3.5" />
                                    )}
                                </span>
                                <span class="flex-1 min-w-0">
                                    <span class="text-[15px] font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent)] transition-colors line-clamp-2">
                                        {item.title}
                                    </span>
                                </span>
                            </a>
                        ))}
                    </div>
                </div>
            )
        }
    </article>
</BaseLayout>

<script>
    document.addEventListener("astro:page-load", () => {
        // Tab switching for full content
        const tabRecap = document.getElementById("tab-recap");
        const tabFull = document.getElementById("tab-full");
        const recapContent = document.getElementById("recap-content");
        const fullContent = document.getElementById("full-content");
        const fullLoading = document.getElementById("full-loading");
        const fullBody = document.getElementById("full-body");
        const fullMeta = document.getElementById("full-meta");

        let fullContentLoaded = false;

        function switchTab(tab: "recap" | "full") {
            if (!tabRecap || !tabFull || !recapContent || !fullContent) return;

            const activeClass = "bg-white text-[var(--color-ink)] shadow-sm";
            const inactiveClass =
                "text-[var(--color-soft)] hover:text-[var(--color-ink)]";

            if (tab === "recap") {
                tabRecap.className = `px-4 py-2 text-sm font-medium rounded-md transition-colors ${activeClass}`;
                tabFull.className = `px-4 py-2 text-sm font-medium rounded-md transition-colors ${inactiveClass}`;
                recapContent.classList.remove("hidden");
                fullContent.classList.add("hidden");
            } else {
                tabFull.className = `px-4 py-2 text-sm font-medium rounded-md transition-colors ${activeClass}`;
                tabRecap.className = `px-4 py-2 text-sm font-medium rounded-md transition-colors ${inactiveClass}`;
                recapContent.classList.add("hidden");
                fullContent.classList.remove("hidden");
                if (!fullContentLoaded) {
                    loadFullContent();
                }
            }
        }

        async function loadFullContent() {
            if (
                !fullLoading ||
                !fullBody ||
                !fullMeta ||
                !tabFull ||
                fullContentLoaded
            )
                return;

            const slug = (tabFull as HTMLElement).dataset.slug;
            if (!slug) return;

            fullLoading.classList.remove("hidden");
            fullBody.innerHTML = "";
            fullMeta.classList.add("hidden");

            try {
                const res = await fetch(`/api/stream-content/${slug}`);
                if (!res.ok) {
                    if (res.status === 404) {
                        fullBody.innerHTML = `<p class="text-[var(--color-soft)] italic">Nội dung gốc không khả dụng cho bài này.</p>`;
                    } else {
                        throw new Error(`HTTP ${res.status}`);
                    }
                    fullLoading.classList.add("hidden");
                    fullContentLoaded = true;
                    return;
                }

                const data = await res.json();
                fullBody.innerHTML = data.content;
                fullMeta.innerHTML = `${data.wordCount.toLocaleString()} từ · <a href="${data.sourceUrl}" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:underline">Xem nguồn gốc</a>`;
                fullMeta.classList.remove("hidden");
                fullContentLoaded = true;
            } catch (err) {
                console.error("Failed to load full content:", err);
                fullBody.innerHTML = `<p class="text-red-500">Không thể tải nội dung. Vui lòng thử lại.</p>`;
            } finally {
                fullLoading.classList.add("hidden");
            }
        }

        if (tabRecap) {
            tabRecap.addEventListener("click", () => switchTab("recap"));
        }
        if (tabFull) {
            tabFull.addEventListener("click", () => switchTab("full"));
        }

        // Share image modal
        document.querySelectorAll(".stream-share-image-btn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.preventDefault();
                if (!(window as any).openShareImageModal) return;

                const el = btn as HTMLElement;
                const title = el.dataset.title || "";
                const slug = "stream/" + (el.dataset.slug || "");
                const type = el.dataset.type || "post";
                const tags = JSON.parse(el.dataset.tags || "[]");

                let firstImage = "";
                const excerpt = el.dataset.excerpt || "";
                const articleBody = document.querySelector(".prose-content");
                if (articleBody) {
                    const img = articleBody.querySelector("img");
                    if (img && img.src) {
                        firstImage = img.src;
                        // Add cache buster for CORS
                        if (firstImage.includes("?")) {
                            firstImage += `&c=${Date.now()}`;
                        } else {
                            firstImage += `?c=${Date.now()}`;
                        }
                    }
                }

                const shareData = {
                    slug: slug,
                    title: title,
                    subtitle: excerpt,
                    format: type === "link" ? "link" : "streaming",
                    tags: tags,
                    heroImage: firstImage,
                };

                (window as any).openShareImageModal(shareData);
            });
        });

        // Copy link
        document.querySelectorAll(".stream-copy-btn").forEach((btn) => {
            btn.addEventListener("click", async () => {
                const slug = (btn as HTMLElement).dataset.slug!;
                const url = `${window.location.origin}/${slug}`;
                try {
                    await navigator.clipboard.writeText(url);
                } catch {
                    const input = document.createElement("input");
                    input.value = url;
                    document.body.appendChild(input);
                    input.select();
                    document.execCommand("copy");
                    input.remove();
                }
                const label = btn.querySelector(".stream-copy-label");
                if (label) {
                    const original = label.textContent;
                    label.textContent = "Copied!";
                    (label as HTMLElement).style.color =
                        "var(--color-green, #1a7f5a)";
                    setTimeout(() => {
                        label.textContent = original;
                        (label as HTMLElement).style.color = "";
                    }, 1500);
                }
            });
        });

        // Native share
        if (navigator.share) {
            document.querySelectorAll(".stream-native-share").forEach((btn) => {
                (btn as HTMLElement).style.display = "inline-flex";
                btn.addEventListener("click", async () => {
                    const el = btn as HTMLElement;
                    try {
                        await navigator.share({
                            title: el.dataset.title || document.title,
                            url: window.location.href,
                        });
                    } catch (e) {
                        if ((e as DOMException).name !== "AbortError") {
                            console.error("Share error:", e);
                        }
                    }
                });
            });
        }
    });
</script>
