---
/**
 * StreamCard — Renders a single stream item.
 * Two variants: 'link' (external URL) and 'post' (short text).
 */
import { ExternalLink, MessageCircle } from "@lucide/astro";
import type { StreamItem } from "../../lib/types";

interface Props {
    item: StreamItem;
    compact?: boolean;
}

const { item, compact = false } = Astro.props;

// Decode HTML entities
function decodeHtmlEntities(text: string): string {
    return text
        .replace(/&quot;/g, '"')
        .replace(/&amp;/g, '&')
        .replace(/&lt;/g, '<')
        .replace(/&gt;/g, '>')
        .replace(/&#39;/g, "'")
        .replace(/&nbsp;/g, ' ');
}

// Extract excerpt from body (first paragraph or ~200 chars)
function getExcerpt(html: string | undefined, maxLength = 200): string {
    if (!html) return "";
    // Strip HTML tags and decode entities
    const text = decodeHtmlEntities(html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim());
    // Get first sentence or truncate
    const firstPara = text.split(/[.!?]\s/)[0];
    if (firstPara.length <= maxLength) return firstPara + (text.length > firstPara.length ? '...' : '');
    return text.slice(0, maxLength).trim() + '...';
}

const excerpt = getExcerpt(item.body);
const hasMoreContent = item.body && item.body.length > 250;

function relativeTime(dateStr: string): string {
    const now = new Date();
    const date = new Date(dateStr);
    const diffMs = now.getTime() - date.getTime();
    const diffMin = Math.floor(diffMs / 60000);
    if (diffMin < 1) return "vừa xong";
    if (diffMin < 60) return `${diffMin}m`;
    const diffHr = Math.floor(diffMin / 60);
    if (diffHr < 24) return `${diffHr}h`;
    const diffDay = Math.floor(diffHr / 24);
    if (diffDay < 7) return `${diffDay}d`;
    return date.toLocaleDateString("vi-VN", { day: "numeric", month: "short" });
}

const timeAgo = relativeTime(item.date);
const isLink = item.type === "link";
---

{compact ? (
    <!-- Compact variant for StreamBox list -->
    <button
        type="button"
        class="stream-item-trigger flex items-start gap-3 w-full text-left py-2.5 px-3 rounded-lg hover:bg-[var(--color-ink)]/[0.03] transition-colors group cursor-pointer"
        data-stream-slug={item.slug}
        data-stream-item={JSON.stringify(item)}
    >
        <span class="mt-0.5 shrink-0 w-5 h-5 flex items-center justify-center text-[var(--color-faint)]">
            {isLink ? (
                <ExternalLink class="w-3.5 h-3.5" />
            ) : (
                <MessageCircle class="w-3.5 h-3.5" />
            )}
        </span>
        <span class="flex-1 min-w-0">
            <span class="text-sm font-medium text-[var(--color-ink)] line-clamp-1 group-hover:text-[var(--color-accent)] transition-colors">
                {item.title}
            </span>
            {isLink && item.source && (
                <span class="text-xs text-[var(--color-faint)] mt-0.5 block">{item.source}</span>
            )}
        </span>
        <span class="text-[11px] text-[var(--color-faint)] shrink-0 mt-0.5 font-medium tabular-nums">
            {timeAgo}
        </span>
    </button>
) : (
    <!-- Full variant for /stream page -->
    <div class="stream-card rounded-xl border border-[var(--color-border)] bg-[var(--color-card,white)] p-5 transition-shadow hover:shadow-sm">
        <div class="flex items-start gap-3 mb-3">
            <span class:list={[
                "w-8 h-8 rounded-lg flex items-center justify-center shrink-0",
                isLink
                    ? "bg-blue-50 text-blue-600"
                    : "bg-violet-50 text-violet-600"
            ]}>
                {isLink ? (
                    <ExternalLink class="w-4 h-4" />
                ) : (
                    <MessageCircle class="w-4 h-4" />
                )}
            </span>
            <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-lg text-[var(--color-ink)] leading-snug">
                    {item.title}
                </h3>
                <div class="flex items-center gap-2 mt-1 text-xs text-[var(--color-faint)]">
                    <time>{timeAgo}</time>
                    {isLink && item.source && (
                        <>
                            <span>·</span>
                            <span class="font-medium">{item.source}</span>
                        </>
                    )}
                </div>
            </div>
        </div>
        {excerpt && (
            <p class="text-base text-[var(--color-soft)] leading-relaxed mb-3">
                {excerpt}
            </p>
        )}
        <div class="flex items-center gap-3">
            {hasMoreContent && (
                <a
                    href={`/stream/${item.slug}`}
                    class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-accent)] hover:underline"
                >
                    Đọc tiếp →
                </a>
            )}
            {isLink && item.url && (
                <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer nofollow"
                    class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-soft)] hover:text-[var(--color-accent)] hover:underline"
                >
                    Nguồn gốc
                    <ExternalLink class="w-3.5 h-3.5" />
                </a>
            )}
        </div>
        <div class="flex items-center justify-between mt-3 pt-3 border-t border-[var(--color-border)]/[0.5]">
            <div class="flex flex-wrap gap-1.5">
                {item.tags.length > 0 && item.tags.map((tag) => (
                    <span class="text-[11px] px-2 py-0.5 rounded-full bg-[var(--color-ink)]/[0.04] text-[var(--color-faint)] font-medium">
                        #{tag}
                    </span>
                ))}
            </div>
            <button
                type="button"
                class="stream-card-share-image inline-flex items-center gap-1 text-[var(--color-soft)] hover:text-[var(--color-ink)] px-2 py-1 -mr-2 rounded-full hover:bg-[var(--color-ink)]/[0.05] transition-colors text-xs font-medium cursor-pointer"
                data-stream-item={JSON.stringify(item)}
                aria-label="Share as image"
                title="Share as image"
            >
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
                Ảnh
            </button>
        </div>
    </div>
)}

<script>
    const INIT_KEY = "__streamCardShareInit";
    document.addEventListener("astro:page-load", () => {
        if ((document as any)[INIT_KEY]) return;
        (document as any)[INIT_KEY] = true;

        document.addEventListener("click", (e) => {
            const target = e.target as HTMLElement;
            const btn = target.closest(".stream-card-share-image") as HTMLElement;
            if (!btn) return;
            e.preventDefault();
            e.stopPropagation();

            if (!(window as any).openShareImageModal) return;

            const card = btn.closest(".stream-card") as HTMLElement;
            if (!card) return;

            try {
                const itemDataStr = btn.dataset.streamItem;
                const item = itemDataStr ? JSON.parse(itemDataStr) : null;
                if (!item) return;

                let firstImage = "";
                const bodyEl = card.querySelector(".stream-body");
                if (bodyEl) {
                    const img = bodyEl.querySelector("img");
                    if (img && img.src) {
                        firstImage = img.src;
                        if (firstImage.includes("?")) {
                            firstImage += `&c=${Date.now()}`;
                        } else {
                            firstImage += `?c=${Date.now()}`;
                        }
                    }
                }

                // Extract excerpt from body in DOM
                let excerpt = "";
                const bodyEl2 = card.querySelector(".stream-body");
                if (bodyEl2) {
                    const text = (bodyEl2.textContent || "").replace(/\s+/g, " ").trim();
                    if (text) {
                        const first = text.split(/[.!?]\s/)[0];
                        excerpt = first.length <= 150 ? first + (text.length > first.length ? "..." : "") : text.slice(0, 150).trim() + "...";
                    }
                }

                const shareData = {
                    slug: `stream/${item.slug}`,
                    title: item.title,
                    subtitle: excerpt,
                    format: item.type === "link" ? "link" : "streaming",
                    tags: item.tags || [],
                    heroImage: firstImage,
                };
                (window as any).openShareImageModal(shareData);

            } catch (err) {
                console.error("Error sharing stream card image", err);
            }
        });
    });
</script>
