---
/**
 * FeedCardArticle — Compact article card for the newsfeed.
 * Reusable: feed, homepage, explore, related posts.
 */
import type { ArticlePost } from "../../lib/types";
import { getTools } from "../../lib/data";

interface Props {
    post: ArticlePost;
}

const { post } = Astro.props;
const allTools = await getTools();
const toolNames = post.tools.map(
    (slug) => allTools.find((t) => t.slug === slug)?.title || slug,
);
---

<a
    href={`/${post.slug}`}
    class="group block py-6 border-t border-border transition-colors hover:bg-ink/[0.015] hover:-mx-5 hover:px-5"
>
    <div class="flex justify-between items-baseline mb-2">
        <h3
            class="font-heading text-xl font-semibold tracking-tight transition-colors group-hover:text-accent"
            transition:name={`title-${post.slug}`}
        >
            {post.title}
        </h3>
        <span
            class="text-xs font-semibold text-soft uppercase tracking-wide ml-4 shrink-0"
        >
            {post.verification === "tonys-pick" && "★ "}{post.stage}
        </span>
    </div>
    {
        post.subtitle && (
            <p
                class="text-base text-soft mb-3 leading-snug"
                transition:name={`subtitle-${post.slug}`}
            >
                {post.subtitle}
            </p>
        )
    }
    <div class="flex gap-2 flex-wrap text-[13px]">
        {
            toolNames.map((name) => (
                <span class="px-2.5 py-1 rounded bg-accent-soft text-accent">
                    {name}
                </span>
            ))
        }
    </div>
</a>
