---
/**
 * FeedCardShortVideo — Vertical video thumbnail card.
 * Reusable: feed, reels page, related content.
 */
import type { ShortVideoPost } from "../../lib/types";

interface Props {
    post: ShortVideoPost;
}

const { post } = Astro.props;

function formatDuration(seconds: number): string {
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${m}:${s.toString().padStart(2, "0")}`;
}
---

<a href={`/reels?v=${post.slug}`} class="group block">
    <div
        class="relative aspect-[9/16] max-h-[360px] rounded-xl overflow-hidden bg-ink/5"
    >
        {
            post.posterUrl ? (
                <img
                    src={post.posterUrl}
                    alt={post.title}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                />
            ) : (
                <div class="w-full h-full bg-gradient-to-br from-accent-soft to-accent-mid flex items-center justify-center">
                    <svg
                        class="w-12 h-12 text-accent"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path d="M8 5v14l11-7z" />
                    </svg>
                </div>
            )
        }
        <!-- Play icon overlay -->
        <div
            class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-ink/20"
        >
            <div
                class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center"
            >
                <svg
                    class="w-6 h-6 text-ink ml-0.5"
                    viewBox="0 0 24 24"
                    fill="currentColor"><path d="M8 5v14l11-7z"></path></svg
                >
            </div>
        </div>
        <!-- Duration badge -->
        <span
            class="absolute bottom-2 right-2 text-xs font-semibold bg-ink/70 text-white px-2 py-0.5 rounded"
        >
            {formatDuration(post.duration)}
        </span>
    </div>
    <h3
        class="mt-3 font-medium text-[15px] leading-snug line-clamp-2 group-hover:text-accent transition-colors"
    >
        {post.title}
    </h3>
    {
        post.subtitle && (
            <p class="mt-1 text-sm text-soft line-clamp-1">{post.subtitle}</p>
        )
    }
</a>
