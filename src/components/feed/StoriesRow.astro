---
/**
 * StoriesRow — Horizontal scrollable row of short video thumbnails.
 * Appears at the top of the feed, like Facebook/Instagram Stories.
 * Reusable: feed, homepage, any page wanting a quick-access reel strip.
 */
import type { ShortVideoPost } from '../../lib/types';
import { getPosts } from '../../lib/data';

interface Props {
  videos?: ShortVideoPost[];
}

const { videos: propVideos } = Astro.props;
const videos = propVideos || ((await getPosts('short-video')) as ShortVideoPost[]);

function formatDuration(seconds: number): string {
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${m}:${s.toString().padStart(2, '0')}`;
}
---

<section class="stories-row mb-8 -mx-6 px-6">
  <div class="flex gap-3 overflow-x-auto pb-3 scrollbar-hide snap-x snap-mandatory">
    {videos.map((video, i) => (
      <a
        href={`/reels?v=${video.slug}`}
        class="group shrink-0 snap-start"
        style={`--delay: ${i}`}
      >
        <div class="relative w-[120px] h-[200px] rounded-lg overflow-hidden bg-ink/5">
          {video.posterUrl ? (
            <img
              src={video.posterUrl}
              alt={video.title}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-full bg-gradient-to-br from-ink/10 to-ink/20 flex items-center justify-center">
              <svg class="w-8 h-8 text-ink/40" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </div>
          )}
          <!-- Gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-ink/60 via-transparent to-transparent" />
          <!-- Play icon -->
          <div class="absolute top-2 right-2 w-6 h-6 rounded-full bg-white/80 flex items-center justify-center opacity-80 group-hover:opacity-100 transition-opacity">
            <svg class="w-3 h-3 text-ink ml-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          </div>
          <!-- Duration -->
          <span class="absolute bottom-2 right-2 text-[10px] font-semibold text-white/90">
            {formatDuration(video.duration)}
          </span>
          <!-- Title -->
          <div class="absolute bottom-2 left-2 right-8">
            <p class="text-[11px] font-medium text-white leading-tight line-clamp-2">
              {video.title}
            </p>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
