---
/**
 * FeedCardVideoEmbed — YouTube/Bunny video embed card.
 * Reusable: feed, article detail, related content.
 */
import type { VideoEmbedPost } from "../../lib/types";

interface Props {
    post: VideoEmbedPost;
}

const { post } = Astro.props;

function getThumbnail(post: VideoEmbedPost): string {
    if (post.provider === "youtube") {
        return `https://img.youtube.com/vi/${post.videoId}/maxresdefault.jpg`;
    }
    return `https://video.bunnycdn.com/play/${post.videoId}/thumbnail.jpg`;
}

function formatDuration(seconds?: number): string {
    if (!seconds) return "";
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${m}:${s.toString().padStart(2, "0")}`;
}
---

<a href={`/${post.slug}`} class="group block">
    <div class="relative aspect-video rounded-xl overflow-hidden bg-ink/5">
        <img
            src={getThumbnail(post)}
            alt={post.title}
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
        />
        <!-- Play button overlay -->
        <div class="absolute inset-0 flex items-center justify-center">
            <div
                class="w-16 h-16 rounded-full bg-white/90 flex items-center justify-center shadow-lg transition-transform group-hover:scale-110"
            >
                <svg
                    class="w-7 h-7 text-ink ml-1"
                    viewBox="0 0 24 24"
                    fill="currentColor"><path d="M8 5v14l11-7z"></path></svg
                >
            </div>
        </div>
        {
            post.duration && (
                <span class="absolute bottom-2 right-2 text-xs font-semibold bg-ink/70 text-white px-2 py-0.5 rounded">
                    {formatDuration(post.duration)}
                </span>
            )
        }
        <!-- Provider badge -->
        <span
            class="absolute top-2 left-2 text-[11px] font-semibold uppercase tracking-wider bg-red-soft text-red px-2 py-0.5 rounded"
        >
            {post.provider}
        </span>
    </div>
    <h3
        class="mt-3 font-heading font-semibold text-lg group-hover:text-accent transition-colors"
    >
        {post.title}
    </h3>
    {
        post.subtitle && (
            <p class="mt-1 text-soft text-[15px] line-clamp-2">
                {post.subtitle}
            </p>
        )
    }
</a>
