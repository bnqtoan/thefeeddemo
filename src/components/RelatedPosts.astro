---
import { getPosts } from "../lib/data";

interface Props {
  currentSlug: string;
  currentTags: string[];
}

const { currentSlug, currentTags } = Astro.props;
const allPosts = await getPosts();

// Find related posts based on shared tags
const related = allPosts
  .filter((p) => p.slug !== currentSlug)
  .map((p) => {
    const sharedTags = p.tags.filter((t) => currentTags.includes(t));
    return { ...p, relevance: sharedTags.length };
  })
  .filter((p) => p.relevance > 0)
  .sort((a, b) => b.relevance - a.relevance)
  .slice(0, 3);
---

{
  related.length > 0 && (
    <section class="related-section" id="related-posts">
      <h2 class="related-title">Continue Reading</h2>
      <div class="related-grid">
        {related.map((c, i) => (
          <a
            href={`/${c.slug}`}
            class="related-card"
            style={`--index: ${i}`}
          >
            <div class="related-card-title">
              {c.title}
            </div>
            {c.subtitle && (
              <div class="related-card-subtitle">
                {c.subtitle}
              </div>
            )}
            <div class="related-card-tools">
              {c.tags.slice(0, 3).map((tag) => (
                <span class="tool-tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>
  )
}

<style>
  .related-section {
    margin-top: 80px;
    padding-top: 48px;
    border-top: 1px solid var(--color-border);
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .related-section.visible { opacity: 1; transform: translateY(0); }

  .related-title {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 28px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .related-card {
    display: block;
    padding: 24px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.25s ease;
    transition-delay: calc(var(--index) * 0.1s + 0.2s);
  }
  .related-section.visible .related-card { opacity: 1; transform: translateY(0); }
  .related-card:hover { border-color: var(--color-accent-mid); transform: translateY(-2px); }
  .related-card:hover .related-card-title { color: var(--color-accent); }

  .related-card-title {
    font-family: var(--font-heading);
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 8px;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .related-card-subtitle {
    font-size: 14px;
    color: var(--color-soft);
    line-height: 1.5;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-card-tools { display: flex; gap: 6px; flex-wrap: wrap; }
  .tool-tag {
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 4px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .related-grid { grid-template-columns: 1fr; gap: 16px; }
    .related-card { padding: 20px; }
  }
</style>

<script>
  function initRelatedPosts() {
    const section = document.getElementById("related-posts");
    if (!section) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add("visible");
            observer.unobserve(section);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
    );
    observer.observe(section);
  }
  document.addEventListener("astro:page-load", initRelatedPosts);
</script>
